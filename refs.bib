	author = {Frasson, Renato Prata De Moraes and Pavelsky, Tamlin M. and Fonstad, Mark A. and Durand, Michael T. and Allen, George H. and Schumann, Guy and Lion, Christine and Beighley, R. Edward and Yang, Xiao},
	month = mar,
	year = {2019},
	note = {Publisher: American Geophysical Union (AGU)},
	pages = {3252--3262},
	file = {Full Text:C\:\\Users\\lrr43\\Zotero\\storage\\NVI77JU2\\Frasson et al. - 2019 - Global Relationships Between River Width, Slope, Catchment Area, Meander Wavelength, Sinuosity, and.pdf:application/pdf},
